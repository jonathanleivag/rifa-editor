  </div>

  <script>
    // Original Baseline Data
    const ORIGINAL_DATA = {
      beneficiary: "MIGUEL RAÚL GÓMEZ",
      description: "RIFA SOLIDARIA A BENEFICIO DE MIGUEL RAÚL GÓMEZ. CADA NÚMERO ES UNA OPORTUNIDAD PARA AYUDAR Y MARCAR LA DIFERENCIA.",
      cost: "$1.000",
      no: "NO ______",
      date: "“EL SORTEO SE REALIZARÁ EL DÍA 23 MAYO”",
      slogan: "TU APOYO CUENTA MÁS DE LO QUE IMAGINAS.",
      rows: 10,
      color: "#4b5d4a",
      scale: 1,
      tableSpacing: 12,
      prizesSpacing: 8,
      columns: ["NOMBRE DE LA PERSONA", "TELÉFONO"],
      surprisePrize: "UN PREMIO SORPRESA",
      prizes: [
        "UNA PARRILLA ELECTRICA",
        "DOS BOTELLAS DE VINO",
        "UN CALEFACTOR",
        "UN HERVIDOR ELECTRICO",
        "UN PACK 4 MINI VINOS",
        "UN JUEGO DE VASOS",
        "UN CHALECO DE MUJER",
        "UN PORTA HIELO"
      ]
    };

    // Alternate prizes demo to show how it looks with other options
    const DEMO_PRIZES = [
      "UNA CANASTA DE ALIMENTOS PREMIUM",
      "UN HORNO MICROONDAS",
      "UN JUEGO DE SÁBANAS 2 PLAZAS",
      "UNA LICUADORA ULTRA",
      "SET DE ASADO (CUCHILLO Y TABLA)",
      "UN PARLANTE BLUETOOTH WATERPROOF",
      "UNA CAFETERA ELÉCTRICA",
      "UNA GIFT CARD DE $20.000"
    ];

    const serverData = window.SERVER_DATA || {};
    const loadedData = serverData.loadedRaffleData;
    const loadedId = serverData.loadedRaffleId;

    let raffleId = loadedId || '';
    let currentPrizes = [...ORIGINAL_DATA.prizes];
    let currentColumns = [...ORIGINAL_DATA.columns];
    let currentParticipants = [];

    // Selectors
    const elements = {
      beneficiary: document.getElementById('input-beneficiary'),
      description: document.getElementById('input-description'),
      cost: document.getElementById('input-cost'),
      no: document.getElementById('input-no'),
      date: document.getElementById('input-date'),
      rows: document.getElementById('input-rows'),
      slogan: document.getElementById('input-slogan'),
      background: document.getElementById('input-background'),
      surprisePrizeInput: document.getElementById('input-surprise-prize'),
      hasSurprise: document.getElementById('input-has-surprise'),
      columnsInputs: document.getElementById('columns-inputs-container'),
      btnAddColumn: document.getElementById('btn-add-column'),
      
      // Styling controls
      colorTheme: document.getElementById('input-color-theme'),
      scale: document.getElementById('input-scale'),
      spacingTable: document.getElementById('input-spacing-table'),
      spacingPrizes: document.getElementById('input-spacing-prizes'),
      
      // Containers
      prizesInputs: document.getElementById('prizes-inputs-container'),
      btnAddPrize: document.getElementById('btn-add-prize'),
      btnShufflePrizes: document.getElementById('btn-shuffle-prizes'),
      btnSaveRaffle: document.getElementById('btn-save-raffle'),
      btnPrint: document.getElementById('btn-print'),
      btnReset: document.getElementById('btn-reset'),
      btnDemoPrizes: document.getElementById('btn-demo-prizes'),
      
      // Previews
      previewNo: document.querySelector('#preview-no-box span'),
      previewDescription: document.getElementById('preview-description-box'),
      previewCost: document.querySelector('#preview-cost-box strong'),
      previewPrizesGrid: document.getElementById('preview-prizes-grid'),
      previewSurpriseContainer: document.getElementById('preview-surprise-container'),
      previewTableBody: document.getElementById('preview-table-body'),
      previewDate: document.getElementById('preview-date-box'),
      previewSlogan: document.getElementById('preview-slogan-box'),
      
      sheet: document.getElementById('raffle-sheet'),
      container: document.querySelector('.preview-container'),
      wrapper: document.querySelector('.sheet-wrapper')
    };

    // Initialize
    function init() {
      // Load event listeners for basic inputs
      const basicBindings = [
        { input: elements.beneficiary, action: updateDescriptionText },
        { input: elements.description, preview: elements.previewDescription },
        { input: elements.cost, preview: elements.previewCost },
        { input: elements.no, preview: elements.previewNo },
        { input: elements.date, preview: elements.previewDate },
        { input: elements.slogan, preview: elements.previewSlogan }
      ];

      basicBindings.forEach(binding => {
        binding.input.addEventListener('input', (e) => {
          if (binding.preview) {
            binding.preview.textContent = e.target.value;
          }
          if (binding.action) {
            binding.action();
          }
          if (binding.input === elements.cost) {
            updateSalesSummary();
          }
        });
      });

      // Special Inputs
      elements.rows.addEventListener('input', () => {
        renderTableRows();
      });
      
      // Styling controls
      elements.colorTheme.addEventListener('input', (e) => {
        document.documentElement.style.setProperty('--theme-color', e.target.value);
        // Make the line color match the theme but semi-transparent
        document.documentElement.style.setProperty('--line-color', hexToRgba(e.target.value, 0.5));
      });

      elements.scale.addEventListener('input', (e) => {
        document.documentElement.style.setProperty('--font-scale', e.target.value);
        triggerResize();
      });

      elements.spacingTable.addEventListener('input', (e) => {
        document.documentElement.style.setProperty('--table-spacing', `${e.target.value}px`);
      });

      elements.spacingPrizes.addEventListener('input', (e) => {
        document.documentElement.style.setProperty('--prizes-spacing', `${e.target.value}px`);
      });

      // Background selector and auto-theme color mapping
      const BACKGROUND_THEMES = {
        '/raffle_bg_1.jpg': '#4b5d4a',
        '/raffle_bg_2.jpg': '#2c5a45',
        '/raffle_bg_3.jpg': '#5a4d75',
        '/raffle_bg_4.jpg': '#a45a3c',
        '/raffle_bg_5.jpg': '#2b4c6f'
      };

      elements.background.addEventListener('change', (e) => {
        const bgUrl = e.target.value;
        elements.sheet.style.backgroundImage = `url('${bgUrl}')`;
        
        // Auto-match color theme
        const targetColor = BACKGROUND_THEMES[bgUrl];
        if (targetColor) {
          elements.colorTheme.value = targetColor;
          document.documentElement.style.setProperty('--theme-color', targetColor);
          document.documentElement.style.setProperty('--line-color', hexToRgba(targetColor, 0.5));
        }
      });

      elements.btnAddPrize.addEventListener('click', addPrizeField);
      elements.btnShufflePrizes.addEventListener('click', shufflePrizes);
      elements.btnAddColumn.addEventListener('click', addColumnField);
      elements.surprisePrizeInput.addEventListener('input', updatePrizesPreview);
      elements.hasSurprise.addEventListener('change', (e) => {
        elements.surprisePrizeInput.disabled = !e.target.checked;
        updatePrizesPreview();
      });
      elements.btnSaveRaffle.addEventListener('click', saveRaffle);
      elements.btnPrint.addEventListener('click', () => window.print());
      elements.btnReset.addEventListener('click', () => resetToOriginal(ORIGINAL_DATA));
      elements.btnDemoPrizes.addEventListener('click', () => {
        currentPrizes = [...DEMO_PRIZES];
        elements.surprisePrizeInput.value = "SORPRESA SECRETA DE LA CASA";
        renderPrizes();
      });

      // Sales handlers
      const btnRegisterSale = document.getElementById('btn-register-sale');
      if (btnRegisterSale) {
        btnRegisterSale.addEventListener('click', registerSale);
      }

      // Set initial values (load if came from db, otherwise use original)
      if (loadedData) {
        loadRaffleData(loadedData);
      } else {
        resetToOriginal(ORIGINAL_DATA);
      }
      
      // Auto-scaling of sheet to fit window
      window.addEventListener('resize', triggerResize);
      setTimeout(triggerResize, 100);
    }

    // Helper for Hex to RGBA
    function hexToRgba(hex, alpha) {
      const r = parseInt(hex.slice(1, 3), 16);
      const g = parseInt(hex.slice(3, 5), 16);
      const b = parseInt(hex.slice(5, 7), 16);
      return `rgba(${r}, ${g}, ${b}, ${alpha})`;
    }

    // Dynamic description updater based on beneficiary name
    function updateDescriptionText() {
      const name = elements.beneficiary.value.toUpperCase();
      const newDesc = `RIFA SOLIDARIA A BENEFICIO DE ${name}. CADA NÚMERO ES UNA OPORTUNIDAD PARA AYUDAR Y MARCAR LA DIFERENCIA.`;
      elements.description.value = newDesc;
      elements.previewDescription.textContent = newDesc;
    }

    // Render the Columns Manager Inputs in Sidebar
    function renderColumnsManager() {
      elements.columnsInputs.innerHTML = '';
      currentColumns.forEach((colName, index) => {
        const item = document.createElement('div');
        item.className = 'prize-item-input';
        
        const num = document.createElement('span');
        num.className = 'prize-num';
        num.textContent = `Col ${index + 1}:`;
        num.style.fontSize = '10px';
        num.style.width = '42px';
        
        const input = document.createElement('input');
        input.type = 'text';
        input.value = colName;
        input.placeholder = `Nombre Columna ${index + 1}`;
        input.addEventListener('input', (e) => {
          currentColumns[index] = e.target.value;
          updateTablePreview();
        });
        
        const btnDelete = document.createElement('button');
        btnDelete.type = 'button';
        btnDelete.className = 'btn-delete-prize';
        btnDelete.innerHTML = '<svg class="icon" style="width:14px;height:14px" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>';
        btnDelete.addEventListener('click', () => {
          currentColumns.splice(index, 1);
          renderColumnsManager();
          updateTablePreview();
        });
        
        item.appendChild(num);
        item.appendChild(input);
        item.appendChild(btnDelete);
        elements.columnsInputs.appendChild(item);
      });
    }

    // Add empty column field
    function addColumnField() {
      currentColumns.push('DIRECCIÓN');
      renderColumnsManager();
      updateTablePreview();
    }

    // Update table headers and columns configuration
    function updateTablePreview() {
      const thead = elements.sheet.querySelector('.participants-table thead tr');
      if (!thead) return;
      thead.innerHTML = '';
      
      // Always add NO.
      const thNo = document.createElement('th');
      thNo.className = 'th-no';
      thNo.textContent = 'NO.';
      thNo.style.width = '8%';
      thead.appendChild(thNo);
      
      // Calculate remaining width dynamically
      const colWidth = currentColumns.length > 0 ? (92 / currentColumns.length) + '%' : '92%';
      
      currentColumns.forEach((colName) => {
        const th = document.createElement('th');
        th.textContent = colName.toUpperCase();
        th.style.width = colWidth;
        thead.appendChild(th);
      });
      
      renderTableRows();
      updateSalesInputs();
    }

    // Update sales summary counter in sidebar
    function updateSalesSummary() {
      const summaryText = document.getElementById('sales-summary-text');
      if (!summaryText) return;
      
      const soldCount = currentParticipants.reduce((sum, p) => sum + (p.quantity || 0), 0);
      summaryText.textContent = `Total Vendidos: ${soldCount} boletos`;
    }

    // Render registered sales list
    function renderSalesList() {
      const container = document.getElementById('sales-list-container');
      if (!container) return;
      container.innerHTML = '';
      
      currentParticipants.forEach((sale, index) => {
        const div = document.createElement('div');
        div.style.display = 'flex';
        div.style.justifyContent = 'space-between';
        div.style.alignItems = 'center';
        div.style.background = 'rgba(255, 255, 255, 0.02)';
        div.style.border = '1px solid var(--border-color)';
        div.style.borderRadius = '6px';
        div.style.padding = '8px 10px';
        div.style.fontSize = '12px';
        
        const info = document.createElement('span');
        info.innerHTML = `<strong style="color:#fff;">${sale.sellerName}</strong>: ${sale.quantity} boleto(s)`;
        
        const btnDelete = document.createElement('button');
        btnDelete.type = 'button';
        btnDelete.style.background = 'none';
        btnDelete.style.border = 'none';
        btnDelete.style.color = '#ef4444';
        btnDelete.style.cursor = 'pointer';
        btnDelete.style.padding = '0';
        btnDelete.style.display = 'flex';
        btnDelete.style.alignItems = 'center';
        btnDelete.innerHTML = '<svg class="icon" style="width:14px;height:14px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>';
        btnDelete.addEventListener('click', () => {
          currentParticipants.splice(index, 1);
          renderSalesList();
          updateSalesSummary();
        });
        
        div.appendChild(info);
        div.appendChild(btnDelete);
        container.appendChild(div);
      });
    }

    // Register sale of raffle tickets
    function registerSale() {
      const nameInput = document.getElementById('input-seller-name');
      const qtyInput = document.getElementById('input-seller-quantity');
      if (!nameInput || !qtyInput) return;
      
      const sellerName = nameInput.value.trim();
      const quantity = parseInt(qtyInput.value) || 0;
      
      if (!sellerName) {
        alert('Por favor ingresa el nombre del vendedor');
        return;
      }
      
      if (quantity <= 0) {
        alert('Por favor ingresa una cantidad válida de boletos vendidos');
        return;
      }
      
      currentParticipants.push({ sellerName, quantity });
      
      // Clear inputs
      nameInput.value = '';
      qtyInput.value = '1';
      
      renderSalesList();
      updateSalesSummary();
      showToast('¡Venta registrada con éxito!');
    }

    // Toast notifications helper
    function showToast(message) {
      let toast = document.getElementById('app-toast');
      if (!toast) {
        toast = document.createElement('div');
        toast.id = 'app-toast';
        toast.style.position = 'fixed';
        toast.style.bottom = '20px';
        toast.style.right = '20px';
        toast.style.background = 'rgba(75, 93, 74, 0.95)';
        toast.style.border = '1px solid rgba(255,255,255,0.1)';
        toast.style.color = '#fff';
        toast.style.padding = '12px 24px';
        toast.style.borderRadius = '8px';
        toast.style.fontFamily = 'inherit';
        toast.style.fontSize = '13px';
        toast.style.fontWeight = '600';
        toast.style.boxShadow = '0 8px 32px rgba(0,0,0,0.5)';
        toast.style.zIndex = '9999';
        toast.style.transition = 'all 0.3s cubic-bezier(0.16, 1, 0.3, 1)';
        toast.style.transform = 'translateY(100px)';
        toast.style.opacity = '0';
        document.body.appendChild(toast);
      }
      
      toast.textContent = message;
      toast.style.transform = 'translateY(0)';
      toast.style.opacity = '1';
      
      setTimeout(() => {
        toast.style.transform = 'translateY(100px)';
        toast.style.opacity = '0';
      }, 3000);
    }

    // Save raffle configuration to database
    async function saveRaffle() {
      const btn = document.getElementById('btn-save-raffle');
      const originalText = btn.innerHTML;
      btn.disabled = true;
      btn.innerHTML = 'Guardando...';
      
      const payload = {
        _id: raffleId,
        beneficiary: elements.beneficiary.value,
        description: elements.description.value,
        cost: elements.cost.value,
        no: elements.no.value,
        date: elements.date.value,
        slogan: elements.slogan.value,
        rows: parseInt(elements.rows.value) || 10,
        color: elements.colorTheme.value,
        scale: parseFloat(elements.scale.value) || 1,
        tableSpacing: parseInt(elements.spacingTable.value) || 12,
        prizesSpacing: parseInt(elements.spacingPrizes.value) || 8,
        background: elements.background.value,
        columns: currentColumns,
        prizes: currentPrizes,
        surprisePrize: elements.surprisePrizeInput.value,
        hasSurprise: elements.hasSurprise.checked,
        participants: currentParticipants
      };
      
      try {
        const res = await fetch('/api/raffles/save', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(payload)
        });
        
        const data = await res.json();
        if (data.success) {
          raffleId = data.id;
          const newUrl = new URL(window.location.href);
          newUrl.searchParams.set('id', raffleId);
          window.history.replaceState({}, '', newUrl);
          
          showToast('¡Rifa guardada correctamente!');
        } else {
          alert('Error al guardar: ' + (data.error || 'Desconocido'));
        }
      } catch (e) {
        console.error('Error al guardar rifa:', e);
        alert('Error de red al guardar la rifa');
      } finally {
        btn.disabled = false;
        btn.innerHTML = originalText;
      }
    }

    // Render Table Rows dynamically based on currentColumns list
    function renderTableRows() {
      const rowCount = parseInt(elements.rows.value) || 10;
      elements.previewTableBody.innerHTML = '';
      
      for (let i = 1; i <= rowCount; i++) {
        const tr = document.createElement('tr');
        
        // NO. cell
        const tdNo = document.createElement('td');
        tdNo.className = 'td-no';
        tdNo.textContent = `${i}.`;
        tr.appendChild(tdNo);
        
        // Custom columns cells
        currentColumns.forEach((colName, colIndex) => {
          const td = document.createElement('td');
          if (colIndex === currentColumns.length - 1) {
            td.className = 'td-phone'; // resets padding-right for last cell
          }
          
          const line = document.createElement('div');
          line.className = 'dotted-line';
          
          // Reset right margin on the last column dotted line
          if (colIndex === currentColumns.length - 1) {
            line.style.marginRight = '0';
          }
          
          td.appendChild(line);
          tr.appendChild(td);
        });
        
        elements.previewTableBody.appendChild(tr);
      }
    }

    // Render Prizes (Inputs & Preview)
    function renderPrizes() {
      // 1. Render Editor Inputs
      elements.prizesInputs.innerHTML = '';
      currentPrizes.forEach((prize, index) => {
        const item = document.createElement('div');
        item.className = 'prize-item-input';
        
        const num = document.createElement('span');
        num.className = 'prize-num';
        num.textContent = `${index + 1}_`;
        
        const input = document.createElement('input');
        input.type = 'text';
        input.value = prize;
        input.placeholder = `Premio ${index + 1}`;
        input.addEventListener('input', (e) => {
          currentPrizes[index] = e.target.value;
          updatePrizesPreview();
        });
        
        const btnDelete = document.createElement('button');
        btnDelete.type = 'button';
        btnDelete.className = 'btn-delete-prize';
        btnDelete.innerHTML = '<svg class="icon" style="width:14px;height:14px" viewBox="0 0 24 24"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>';
        btnDelete.addEventListener('click', () => {
          currentPrizes.splice(index, 1);
          renderPrizes();
        });
        
        item.appendChild(num);
        item.appendChild(input);
        item.appendChild(btnDelete);
        elements.prizesInputs.appendChild(item);
      });

      updatePrizesPreview();
    }

    // Update only the preview container for prizes (combines regulars and dynamic surprise field)
    function updatePrizesPreview() {
      elements.previewPrizesGrid.innerHTML = '';
      elements.previewSurpriseContainer.innerHTML = '';
      
      // 1. Render main prizes
      currentPrizes.forEach((prize, index) => {
        const li = document.createElement('li');
        
        const spanNum = document.createElement('span');
        spanNum.className = 'num';
        spanNum.textContent = `${index + 1}_`;
        
        const textNode = document.createTextNode(prize);
        
        li.appendChild(spanNum);
        li.appendChild(textNode);
        elements.previewPrizesGrid.appendChild(li);
      });
      
      // 2. Render surprise prize in its own separate container if checked and not empty
      const isChecked = elements.hasSurprise.checked;
      const surpriseText = elements.surprisePrizeInput.value.trim();
      if (isChecked && surpriseText) {
        const div = document.createElement('div');
        div.className = 'surprise-prize-preview';
        
        const iconSpan = document.createElement('span');
        iconSpan.textContent = '✦';
        iconSpan.style.color = 'var(--theme-color)';
        
        const labelSpan = document.createElement('strong');
        labelSpan.textContent = 'PREMIO SORPRESA: ';
        labelSpan.style.marginRight = '4px';
        
        const textSpan = document.createElement('span');
        textSpan.textContent = surpriseText.toUpperCase();
        textSpan.style.fontWeight = '600';
        textSpan.style.color = 'var(--text-dark)';
        
        div.appendChild(iconSpan);
        div.appendChild(labelSpan);
        div.appendChild(textSpan);
        
        elements.previewSurpriseContainer.appendChild(div);
      }
      
      triggerResize();
    }

    // Add empty prize field
    function addPrizeField() {
      currentPrizes.push('');
      renderPrizes();
    }

    // Shuffles regular prizes. The surprise prize is managed separately and remains at the bottom.
    function shufflePrizes() {
      // Fisher-Yates Shuffle
      for (let i = currentPrizes.length - 1; i > 0; i--) {
        const j = Math.floor(Math.random() * (i + 1));
        [currentPrizes[i], currentPrizes[j]] = [currentPrizes[j], currentPrizes[i]];
      }
      renderPrizes();
    }

    // Load full raffle configurations
    function loadRaffleData(data) {
      elements.beneficiary.value = data.beneficiary;
      elements.description.value = data.description;
      elements.cost.value = data.cost;
      elements.no.value = data.no;
      elements.date.value = data.date;
      elements.rows.value = data.rows;
      elements.slogan.value = data.slogan;
      elements.background.value = data.background || '/raffle_bg_1.jpg';
      elements.sheet.style.backgroundImage = `url('${data.background || '/raffle_bg_1.jpg'}')`;
      
      elements.colorTheme.value = data.color;
      elements.scale.value = data.scale;
      elements.spacingTable.value = data.tableSpacing;
      elements.spacingPrizes.value = data.prizesSpacing;
      
      document.documentElement.style.setProperty('--theme-color', data.color);
      document.documentElement.style.setProperty('--line-color', hexToRgba(data.color, 0.5));
      document.documentElement.style.setProperty('--font-scale', data.scale);
      document.documentElement.style.setProperty('--table-spacing', `${data.tableSpacing}px`);
      document.documentElement.style.setProperty('--prizes-spacing', `${data.prizesSpacing}px`);
      
      elements.previewNo.textContent = data.no;
      elements.previewDescription.textContent = data.description;
      elements.previewCost.textContent = data.cost;
      elements.previewDate.textContent = data.date;
      elements.previewSlogan.textContent = data.slogan;

      currentPrizes = [...data.prizes];
      currentColumns = [...data.columns];
      currentParticipants = [...(data.participants || [])];
      
      if (data.hasSurprise && data.surprisePrize) {
        elements.hasSurprise.checked = true;
        elements.surprisePrizeInput.disabled = false;
        elements.surprisePrizeInput.value = data.surprisePrize;
      } else {
        elements.hasSurprise.checked = false;
        elements.surprisePrizeInput.disabled = true;
        elements.surprisePrizeInput.value = '';
      }

      renderPrizes();
      renderColumnsManager();
      updateTablePreview();
      renderSalesList();
      updateSalesSummary();
      triggerResize();
    }

    // Reset fields to target data
    function resetToOriginal(data) {
      elements.beneficiary.value = data.beneficiary;
      elements.description.value = data.description;
      elements.cost.value = data.cost;
      elements.no.value = data.no;
      elements.date.value = data.date;
      elements.rows.value = data.rows;
      elements.slogan.value = data.slogan;
      elements.background.value = '/raffle_bg_1.jpg';
      elements.sheet.style.backgroundImage = `url('/raffle_bg_1.jpg')`;
      elements.surprisePrizeInput.value = data.surprisePrize;
      
      elements.colorTheme.value = data.color;
      elements.scale.value = data.scale;
      elements.spacingTable.value = data.tableSpacing;
      elements.spacingPrizes.value = data.prizesSpacing;
      
      document.documentElement.style.setProperty('--theme-color', data.color);
      document.documentElement.style.setProperty('--line-color', hexToRgba(data.color, 0.5));
      document.documentElement.style.setProperty('--font-scale', data.scale);
      document.documentElement.style.setProperty('--table-spacing', `${data.tableSpacing}px`);
      document.documentElement.style.setProperty('--prizes-spacing', `${data.prizesSpacing}px`);
      
      elements.previewNo.textContent = data.no;
      elements.previewDescription.textContent = data.description;
      elements.previewCost.textContent = data.cost;
      elements.previewDate.textContent = data.date;
      elements.previewSlogan.textContent = data.slogan;

      currentPrizes = [...data.prizes];
      currentColumns = [...data.columns];
      currentParticipants = [];
      
      renderPrizes();
      renderColumnsManager();
      updateTablePreview();
      renderSalesList();
      updateSalesSummary();
      triggerResize();
    }

    // Handles smart resizing of preview sheet within standard layouts
    function triggerResize() {
      const containerWidth = elements.container.clientWidth - 48; // padding
      const containerHeight = elements.container.clientHeight - 48;
      
      const sheetWidth = 794;
      const sheetHeight = 1123;
      
      const scaleX = containerWidth / sheetWidth;
      const scaleY = containerHeight / sheetHeight;
      const scale = Math.min(scaleX, scaleY, 1); // Max scale 1
      
      elements.sheet.style.transform = `translate(-50%, 0) scale(${scale})`;
      elements.wrapper.style.width = `${sheetWidth * scale}px`;
      elements.wrapper.style.height = `${sheetHeight * scale}px`;
    }

    // Initialize on page load
    window.addEventListener('DOMContentLoaded', init);
  </script>
</body>
</html>
