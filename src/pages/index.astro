---
import { getUserFromRequest } from '../lib/auth';
import { getDb } from '../lib/db';
import { ObjectId } from 'mongodb';

const user = await getUserFromRequest(Astro.request);
if (!user) {
  return Astro.redirect('/login');
}

const db = await getDb();
let loadedRaffleData = null;
let loadedRaffleId = '';

const url = new URL(Astro.request.url);
const raffleIdStr = url.searchParams.get('id');
if (raffleIdStr) {
  try {
    const raffle = await db.collection('raffles').findOne({ _id: new ObjectId(raffleIdStr), userId: user._id });
    if (raffle) {
      loadedRaffleData = raffle;
      loadedRaffleId = raffle._id.toString();
    }
  } catch (e) {
    console.error('Error al cargar rifa:', e);
  }
}
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Diseñador y Editor de Rifa Solidaria (Astro)</title>
  <link rel="icon" type="image/jpeg" href="/favicon.jpg">
  <!-- Google Fonts: Cinzel for headers, Montserrat for clean sans-serif text -->
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;600;700;800&family=Montserrat:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
  
  <style is:global>
    /* Design Tokens */
    :root {
      --bg-dark: #0f1311;
      --panel-bg: rgba(22, 28, 25, 0.9);
      --border-color: rgba(255, 255, 255, 0.08);
      --accent-color: #7b8e78;
      --accent-hover: #96aa93;
      --text-light: #e3e8e5;
      --text-muted: #9ba8a0;
      
      /* Raffle Preview Config (Live updated via CSS Variables) */
      --theme-color: #4b5d4a; /* Classic Olive Green from original */
      --text-dark: #2c352b;
      --line-color: rgba(75, 93, 74, 0.5);
      --font-scale: 1;
      --table-spacing: 12px;
      --prizes-spacing: 8px;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Montserrat', sans-serif;
      background-color: var(--bg-dark);
      color: var(--text-light);
      min-height: 100vh;
      display: flex;
      overflow-x: hidden;
    }

    /* Layout structure */
    .app-container {
      display: flex;
      width: 100vw;
      height: 100vh;
    }

    /* Left panel: Editor controls */
    .editor-panel {
      width: 450px;
      min-width: 400px;
      height: 100%;
      background-color: var(--panel-bg);
      border-right: 1px solid var(--border-color);
      display: flex;
      flex-direction: column;
      backdrop-filter: blur(16px);
      box-shadow: 10px 0 30px rgba(0, 0, 0, 0.3);
      z-index: 10;
    }

    .editor-header {
      padding: 24px;
      border-bottom: 1px solid var(--border-color);
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .editor-header h1 {
      font-size: 20px;
      font-weight: 700;
      letter-spacing: 0.5px;
      color: #fff;
    }

    .editor-scroll {
      flex: 1;
      overflow-y: auto;
      padding: 24px;
    }

    /* Form Fields */
    .form-group {
      margin-bottom: 20px;
    }

    .form-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 12px;
    }

    label {
      display: block;
      font-size: 11px;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      color: var(--text-muted);
      margin-bottom: 8px;
    }

    input[type="text"],
    textarea,
    input[type="number"] {
      width: 100%;
      background: rgba(255, 255, 255, 0.04);
      border: 1px solid var(--border-color);
      border-radius: 6px;
      padding: 10px 12px;
      font-family: inherit;
      font-size: 13px;
      color: var(--text-light);
      transition: all 0.2s ease;
    }

    input[type="text"]:focus,
    textarea:focus,
    input[type="number"]:focus {
      outline: none;
      border-color: var(--accent-color);
      background: rgba(255, 255, 255, 0.07);
      box-shadow: 0 0 0 3px rgba(123, 142, 120, 0.25);
    }

    textarea {
      resize: vertical;
      min-height: 70px;
    }

    /* Prize list manager */
    .prizes-manager {
      background: rgba(255, 255, 255, 0.02);
      border: 1px dashed var(--border-color);
      border-radius: 8px;
      padding: 16px;
      margin-bottom: 20px;
    }

    .prize-item-input {
      display: flex;
      gap: 8px;
      margin-bottom: 8px;
      align-items: center;
    }

    .prize-item-input input {
      flex: 1;
    }

    .prize-num {
      font-size: 12px;
      font-weight: 700;
      color: var(--accent-color);
      width: 24px;
      text-align: center;
    }

    .btn-delete-prize {
      background: transparent;
      border: none;
      color: #ff6b6b;
      cursor: pointer;
      padding: 8px;
      border-radius: 4px;
      transition: background 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .btn-delete-prize:hover {
      background: rgba(255, 107, 107, 0.1);
    }

    .btn-add-prize {
      background: rgba(255, 255, 255, 0.05);
      border: 1px solid var(--border-color);
      border-radius: 6px;
      color: var(--text-light);
      padding: 8px 12px;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      width: 100%;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
      margin-top: 10px;
    }

    .btn-add-prize:hover {
      background: rgba(255, 255, 255, 0.1);
      border-color: var(--accent-color);
    }

    /* Style adjustments sliders */
    .slider-group {
      background: rgba(255, 255, 255, 0.02);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 16px;
      margin-bottom: 24px;
    }

    .slider-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 12px;
    }

    .slider-row:last-child {
      margin-bottom: 0;
    }

    .slider-row label {
      margin-bottom: 0;
    }

    input[type="range"] {
      width: 120px;
      accent-color: var(--accent-color);
      cursor: pointer;
    }

    input[type="color"] {
      border: none;
      width: 40px;
      height: 25px;
      border-radius: 4px;
      cursor: pointer;
      background: transparent;
    }

    /* Action buttons in footer of sidebar */
    .editor-footer {
      padding: 24px;
      border-top: 1px solid var(--border-color);
      background: rgba(0, 0, 0, 0.2);
    }

    .btn-primary {
      width: 100%;
      background: var(--accent-color);
      color: #fff;
      border: none;
      border-radius: 8px;
      padding: 14px 20px;
      font-size: 15px;
      font-weight: 700;
      cursor: pointer;
      transition: background 0.2s, transform 0.1s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 8px;
      box-shadow: 0 4px 15px rgba(123, 142, 120, 0.3);
    }

    .btn-primary:hover {
      background: var(--accent-hover);
      transform: translateY(-1px);
    }

    .btn-primary:active {
      transform: translateY(1px);
    }

    .btn-secondary-row {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 10px;
      margin-top: 10px;
    }

    .btn-secondary {
      background: transparent;
      border: 1px solid var(--border-color);
      border-radius: 6px;
      color: var(--text-light);
      padding: 8px 12px;
      font-size: 12px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 6px;
    }

    .btn-secondary:hover {
      background: rgba(255, 255, 255, 0.05);
      border-color: var(--text-muted);
    }

    /* Right panel: Live Preview Container */
    .preview-container {
      flex: 1;
      height: 100%;
      overflow: auto;
      background-color: #2b302c;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 40px;
      position: relative;
    }

    /* The outer wrapper scales the A4 sheet to fit the preview container */
    .sheet-wrapper {
      transition: all 0.2s ease;
      position: relative;
      width: 794px;
      height: 1123px;
    }

    /* The actual A4 Sheet format (at 96 DPI: 210mm x 297mm is ~794px x 1123px) */
    .a4-sheet {
      position: absolute;
      left: 50%;
      top: 0;
      width: 794px;
      height: 1123px;
      min-width: 794px;
      min-height: 1123px;
      flex-shrink: 0;
      background-color: #faf7f2;
      background-image: url('/raffle_bg_1.jpg');
      background-size: cover;
      background-position: center;
      box-shadow: 0 20px 50px rgba(0, 0, 0, 0.4);
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      padding: 60px 70px 50px 70px;
      box-sizing: border-box;
      overflow: hidden;
      color: var(--text-dark);
      transform-origin: top center;
    }

    /* Lightening overlay for background image to enhance contrast */
    .a4-sheet::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(250, 247, 242, 0.45); /* 45% cream opacity */
      pointer-events: none;
      z-index: 1;
    }

    /* Raffle contents styling */
    .sheet-header,
    .prizes-section,
    .table-section,
    .sheet-footer {
      position: relative;
      z-index: 2;
    }

    .sheet-header {
      display: grid;
      grid-template-columns: 1.3fr 1fr;
      gap: 25px;
      align-items: start;
    }

    .header-left {
      display: flex;
      flex-direction: column;
    }

    .ticket-no {
      font-size: calc(14px * var(--font-scale));
      font-weight: 700;
      color: var(--theme-color);
      letter-spacing: 2px;
      margin-bottom: calc(18px * var(--font-scale));
    }

    .ticket-no span {
      border-bottom: 2px solid var(--theme-color);
      padding-bottom: 2px;
      display: inline-block;
      min-width: 80px;
    }

    .raffle-title-box h2 {
      font-family: 'Cinzel', serif;
      font-size: calc(64px * var(--font-scale));
      font-weight: 800;
      color: var(--theme-color);
      line-height: 0.9;
      margin: 0;
      letter-spacing: 1px;
      text-shadow: 0 0 6px #faf7f2, 0 0 2px #faf7f2;
    }

    .raffle-title-box h3 {
      font-family: 'Cinzel', serif;
      font-size: calc(23px * var(--font-scale));
      font-weight: 700;
      color: var(--theme-color);
      line-height: 1.1;
      margin: 0 0 calc(20px * var(--font-scale)) 0;
      letter-spacing: 6.5px;
      text-shadow: 0 0 6px #faf7f2, 0 0 2px #faf7f2;
    }

    .cost-badge {
      font-size: calc(14px * var(--font-scale));
      font-weight: 500;
      color: var(--text-dark);
      text-shadow: 0 0 4px #faf7f2;
    }

    .cost-badge strong {
      font-size: calc(19px * var(--font-scale));
      font-weight: 700;
      color: var(--theme-color);
    }

    .header-right {
      height: 100%;
      border-left: 2px solid var(--theme-color);
      padding-left: 20px;
      display: flex;
      align-items: center;
    }

    .beneficiary-text {
      font-size: calc(11px * var(--font-scale));
      line-height: 1.6;
      color: var(--text-dark);
      text-transform: uppercase;
      font-weight: 600;
      letter-spacing: 0.8px;
      text-align: justify;
    }

    /* Prizes Section */
    .prizes-section {
      margin-top: calc(15px * var(--font-scale));
      margin-bottom: calc(10px * var(--font-scale));
    }

    .prizes-section h4 {
      font-size: calc(13px * var(--font-scale));
      font-weight: 800;
      text-transform: uppercase;
      color: var(--theme-color);
      letter-spacing: 2px;
      margin-bottom: calc(8px * var(--font-scale));
      border-bottom: 1.5px solid var(--theme-color);
      padding-bottom: 2px;
      display: inline-block;
    }

    .prizes-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: var(--prizes-spacing) 25px;
      list-style-type: none;
      padding: 0;
      margin: 0;
    }

    .prizes-grid li {
      font-size: calc(11.5px * var(--font-scale));
      font-weight: 600;
      color: var(--text-dark);
      text-transform: uppercase;
      display: flex;
      align-items: baseline;
      letter-spacing: 0.2px;
      text-shadow: 0 0 4px #faf7f2, 0 0 1px #faf7f2;
    }

    .prizes-grid li span.num {
      color: var(--theme-color);
      font-weight: 800;
      margin-right: 6px;
      font-size: calc(12px * var(--font-scale));
    }

    .surprise-prize-preview {
      margin-top: calc(10px * var(--font-scale));
      padding-top: calc(8px * var(--font-scale));
      border-top: 1px dashed var(--line-color);
      font-size: calc(12px * var(--font-scale));
      font-weight: 800;
      color: var(--theme-color);
      text-transform: uppercase;
      letter-spacing: 0.8px;
      text-shadow: 0 0 4px #faf7f2, 0 0 1px #faf7f2;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    /* Table Section */
    .table-section {
      flex: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      margin: calc(10px * var(--font-scale)) 0;
    }

    .participants-table {
      width: 100%;
      border-collapse: collapse;
    }

    .participants-table th {
      font-size: calc(11px * var(--font-scale));
      font-weight: 800;
      color: var(--theme-color);
      text-transform: uppercase;
      letter-spacing: 1.5px;
      padding-bottom: 8px;
      border-bottom: 2px solid var(--theme-color);
    }

    .th-no { text-align: left; width: 8%; }
    .th-name { text-align: left; width: 62%; }
    .th-phone { text-align: left; width: 30%; }

    .participants-table td {
      padding: var(--table-spacing) 0;
      font-size: calc(13px * var(--font-scale));
      font-weight: 600;
      color: var(--text-dark);
      vertical-align: bottom;
    }

    .td-no {
      font-weight: 700;
    }

    .dotted-line {
      border-bottom: 1.5px dotted var(--line-color);
      height: calc(13px * var(--font-scale));
      margin-right: 15px;
    }

    .td-phone .dotted-line {
      margin-right: 0;
    }

    /* Footer Section */
    .sheet-footer {
      text-align: center;
      border-top: 1px solid rgba(75, 93, 74, 0.15);
      padding-top: calc(15px * var(--font-scale));
      display: flex;
      flex-direction: column;
      gap: 5px;
    }

    .draw-date {
      font-size: calc(14px * var(--font-scale));
      font-weight: 800;
      color: var(--theme-color);
      letter-spacing: 1px;
    }

    .footer-slogan {
      font-size: calc(10px * var(--font-scale));
      font-weight: 600;
      color: rgba(44, 53, 43, 0.7);
      text-transform: uppercase;
      letter-spacing: 1.5px;
    }

    /* SVG Icon Helpers */
    .icon {
      width: 16px;
      height: 16px;
      stroke: currentColor;
      stroke-width: 2;
      stroke-linecap: round;
      stroke-linejoin: round;
      fill: none;
    }

    /* Print styling rules */
    @media print {
      @page {
        size: A4 portrait;
        margin: 0 !important;
      }
      body {
        background-color: #fff !important;
        color: #000 !important;
        margin: 0 !important;
        padding: 0 !important;
      }
      .editor-panel {
        display: none !important;
      }
      .preview-container {
        display: block !important;
        padding: 0 !important;
        margin: 0 !important;
        background: transparent !important;
        width: 210mm !important;
        height: 297mm !important;
        overflow: visible !important;
        position: absolute !important;
        top: 0 !important;
        left: 0 !important;
      }
      .sheet-wrapper {
        transform: none !important;
        height: 297mm !important;
        width: 210mm !important;
        margin: 0 !important;
        padding: 0 !important;
        display: block !important;
      }
      .a4-sheet {
        position: relative !important;
        left: 0 !important;
        top: 0 !important;
        transform: none !important;
        box-shadow: none !important;
        border: none !important;
        width: 210mm !important;
        height: 297mm !important;
        margin: 0 !important;
        padding: 20mm 15mm 15mm 15mm !important;
        box-sizing: border-box !important;
        page-break-after: avoid !important;
        page-break-before: avoid !important;
        page-break-inside: avoid !important;
        break-inside: avoid !important;
        /* Force printing backgrounds */
        -webkit-print-color-adjust: exact !important;
        print-color-adjust: exact !important;
      }
    }
  </style>
</head>
<body>

  <div class="app-container">
    <!-- Left Sidebar: Controls -->
    <aside class="editor-panel">
      <!-- User profile header -->
      <div style="background: rgba(255,255,255,0.02); border: 1px solid var(--border-color); border-radius: 8px; padding: 12px; margin-bottom: 20px; display: flex; align-items: center; justify-content: space-between; gap: 10px;">
        <div style="display: flex; flex-direction: column; gap: 2px;">
          <span style="font-size: 9px; font-weight: bold; text-transform: uppercase; color: var(--text-gray);">Usuario Activo</span>
          <span style="font-size: 13px; font-weight: 700; color: #fff;">{user.username}</span>
        </div>
        <div style="display: flex; gap: 6px;">
          <a href="/history" style="text-decoration: none; border: 1px solid var(--border-color); border-radius: 6px; padding: 6px 10px; font-size: 11px; font-weight: 600; color: var(--text-light); background: rgba(255,255,255,0.04); cursor: pointer; transition: all 0.2s;">Historial</a>
          <a href="/logout" style="text-decoration: none; border: 1px solid rgba(239, 68, 68, 0.2); border-radius: 6px; padding: 6px 10px; font-size: 11px; font-weight: 600; color: #ef4444; background: rgba(239, 68, 68, 0.1); cursor: pointer; transition: all 0.2s;">Salir</a>
        </div>
      </div>

      <div class="editor-header">
        <h1>Modificar Rifa</h1>
        <svg class="icon" style="color: var(--accent-color)" viewBox="0 0 24 24"><path d="M12 20h9M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/></svg>
      </div>
      
      <div class="editor-scroll">
        <!-- Text details -->
        <div class="form-group">
          <label for="input-beneficiary">Nombre del Beneficiario</label>
          <input type="text" id="input-beneficiary" value="MIGUEL RAÚL GÓMEZ">
        </div>

        <div class="form-group">
          <label for="input-description">Descripción / Propósito</label>
          <textarea id="input-description">RIFA SOLIDARIA A BENEFICIO DE MIGUEL RAÚL GÓMEZ. CADA NÚMERO ES UNA OPORTUNIDAD PARA AYUDAR Y MARCAR LA DIFERENCIA.</textarea>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="input-cost">Costo del Número</label>
            <input type="text" id="input-cost" value="$1.000">
          </div>
          <div class="form-group">
            <label for="input-no">Etiqueta Número</label>
            <input type="text" id="input-no" value="NO ______">
          </div>
        </div>
        <!-- Dynamic prizes list -->
        <div class="form-group">
          <label>Premios</label>
          <div class="prizes-manager" id="prizes-inputs-container">
            <!-- Populated dynamically via JS -->
          </div>
          <div class="form-row" style="margin-top: 10px;">
            <button type="button" class="btn-add-prize" id="btn-add-prize" style="margin-top: 0;">
              <svg class="icon" style="width: 14px; height: 14px;" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
              Agregar Premio
            </button>
            <button type="button" class="btn-add-prize" id="btn-shuffle-prizes" style="margin-top: 0;">
              <svg class="icon" viewBox="0 0 24 24"><path d="M16 3h5v5M4 20L21 3M21 16v5h-5M15 15l6 6M4 4l5 5"/></svg>
              Desordenar
            </button>
          </div>
        </div>

        <div class="form-group">
          <div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
            <input type="checkbox" id="input-has-surprise" checked style="width: auto; cursor: pointer; margin: 0;">
            <label for="input-has-surprise" style="margin: 0; cursor: pointer; font-size: 13px; font-weight: 600;">Incluir Premio Sorpresa</label>
          </div>
          <input type="text" id="input-surprise-prize" value="UN PREMIO SORPRESA" placeholder="Escribe el premio sorpresa...">
        </div>

        <div class="form-row">
          <div class="form-group">
            <label for="input-date">Fecha Sorteo</label>
            <input type="text" id="input-date" value="“EL SORTEO SE REALIZARÁ EL DÍA 23 MAYO”">
          </div>
          <div class="form-group">
            <label for="input-rows">Filas de Tabla</label>
            <input type="number" id="input-rows" min="1" max="15" value="10">
          </div>
        </div>

        <div class="form-group">
          <label for="input-slogan">Eslogan de Pie</label>
          <input type="text" id="input-slogan" value="TU APOYO CUENTA MÁS DE LO QUE IMAGINAS.">
        </div>

        <div class="form-group">
          <label>Columnas de la Tabla</label>
          <div class="prizes-manager" id="columns-inputs-container" style="background: rgba(255, 255, 255, 0.02); border: 1px dashed var(--border-color); border-radius: 8px; padding: 16px; margin-bottom: 10px;">
            <!-- Populated dynamically via JS -->
          </div>
          <button type="button" class="btn-add-prize" id="btn-add-column" style="margin-top: 0;">
            <svg class="icon" style="width: 14px; height: 14px;" viewBox="0 0 24 24"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
            Agregar Columna
          </button>
        </div>

        <!-- Dynamic sales registrator -->
        <div class="form-group" style="background: rgba(255, 255, 255, 0.02); border: 1px dashed var(--border-color); border-radius: 8px; padding: 14px; margin-bottom: 15px;">
          <label style="color: #fff; font-size: 11px; margin-bottom: 10px; display: block; border-bottom: 1px solid var(--border-color); padding-bottom: 4px;">Registro de Ventas</label>
          <div style="margin-top: -4px; margin-bottom: 12px;">
            <span id="sales-summary-text" style="font-size: 11px; color: var(--text-gray); font-weight: 500;">Total Vendidos: 0 boletos</span>
          </div>
          <div class="form-row" style="margin-bottom: 8px; gap: 8px;">
            <div style="display: flex; flex-direction: column; width: 65%;">
              <label for="input-seller-name" style="font-size: 9px; margin-bottom: 4px;">Nombre del Vendedor</label>
              <input type="text" id="input-seller-name" placeholder="Ej: Juan Pérez" style="width: 100%; background: rgba(255, 255, 255, 0.04); border: 1px solid var(--border-color); border-radius: 6px; padding: 8px 10px; font-family: inherit; font-size: 12px; color: var(--text-light);">
            </div>
            <div style="display: flex; flex-direction: column; width: 35%;">
              <label for="input-seller-quantity" style="font-size: 9px; margin-bottom: 4px;">Boletos</label>
              <input type="number" id="input-seller-quantity" min="1" value="1" style="width: 100%; background: rgba(255, 255, 255, 0.04); border: 1px solid var(--border-color); border-radius: 6px; padding: 8px 10px; font-family: inherit; font-size: 12px; color: var(--text-light);">
            </div>
          </div>
          <div class="form-row" style="margin-top: 6px; margin-bottom: 12px;">
            <button type="button" class="btn-add-prize" id="btn-register-sale" style="margin-top: 0; background: var(--accent-color); color: #fff; font-size: 11px; padding: 8px 10px; width: 100%;">
              Registrar Venta
            </button>
          </div>
          
          <!-- Sales List Container -->
          <div id="sales-list-container" style="display: flex; flex-direction: column; gap: 6px; max-height: 150px; overflow-y: auto; padding-right: 4px;">
            <!-- Rendered dynamically -->
          </div>
        </div>

        <div class="form-group">
          <label for="input-background">Fondo Estético</label>
          <select id="input-background" style="width: 100%; background: rgba(255, 255, 255, 0.04); border: 1px solid var(--border-color); border-radius: 6px; padding: 10px 12px; font-family: inherit; font-size: 13px; color: var(--text-light); cursor: pointer;">
            <option value="/raffle_bg_1.jpg">1. Botánico y Terracota (Original)</option>
            <option value="/raffle_bg_2.jpg">2. Esmeralda y Oro Lujoso</option>
            <option value="/raffle_bg_3.jpg">3. Lavanda y Flores Silvestres</option>
            <option value="/raffle_bg_4.jpg">4. Geométrico Terracota Moderno</option>
            <option value="/raffle_bg_5.jpg">5. Slate Azul y Plata Elegante</option>
          </select>
        </div>

        <!-- Custom sliders for design fine tuning -->
        <div class="slider-group">
          <label style="color: #fff; border-bottom: 1px solid var(--border-color); padding-bottom: 6px; margin-bottom: 12px; display: block;">Ajustes de Diseño</label>
          
          <div class="slider-row">
            <label>Color Principal</label>
            <input type="color" id="input-color-theme" value="#4b5d4a">
          </div>

          <div class="slider-row">
            <label>Escala de Fuentes</label>
            <input type="range" id="input-scale" min="0.8" max="1.2" step="0.05" value="1">
          </div>

          <div class="slider-row">
            <label>Espacio Tabla</label>
            <input type="range" id="input-spacing-table" min="6" max="22" step="1" value="12">
          </div>

          <div class="slider-row">
            <label>Espacio Premios</label>
            <input type="range" id="input-spacing-prizes" min="4" max="16" step="1" value="8">
          </div>
        </div>
      </div>
      
      <div class="editor-footer">
        <div class="form-row" style="margin-bottom: 8px; gap: 8px;">
          <button type="button" class="btn-primary" id="btn-save-raffle" style="background: var(--accent-color); margin-top: 0; box-shadow: 0 4px 12px rgba(123, 142, 120, 0.2); font-size: 11px; padding: 10px 12px;">
            <svg class="icon" style="width: 14px; height: 14px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"></path><polyline points="17 21 17 13 7 13 7 21"></polyline><polyline points="7 3 7 8 15 8"></polyline></svg>
            Guardar Rifa
          </button>
          <button type="button" class="btn-primary" id="btn-print" style="margin-top: 0; font-size: 11px; padding: 10px 12px;">
            <svg class="icon" viewBox="0 0 24 24"><path d="M6 9V2h12v7M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
            Imprimir PDF
          </button>
        </div>
        <div class="btn-secondary-row">
          <button type="button" class="btn-secondary" id="btn-reset">
            <svg class="icon" viewBox="0 0 24 24"><path d="M21.5 2v6h-6M21.34 15.57a10 10 0 1 1-.57-8.38l5.67-5.67"/></svg>
            Original
          </button>
          <button type="button" class="btn-secondary" id="btn-demo-prizes">
            <svg class="icon" viewBox="0 0 24 24"><path d="M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5"/></svg>
            Premios Demo
          </button>
        </div>
      </div>
    </aside>

    <!-- Inject server-rendered variables dynamically for JS state -->
    <script is:inline define:vars={{ loadedRaffleData, loadedRaffleId }}>
      window.SERVER_DATA = {
        loadedRaffleData,
        loadedRaffleId
      };
    </script>

    <!-- Right Main Area: Print Preview -->
    <main class="preview-container">
      <div class="sheet-wrapper">
        <div class="a4-sheet" id="raffle-sheet">
          
          <!-- Top section -->
          <div class="sheet-header">
            <div class="header-left">
              <div class="ticket-no" id="preview-no-box"><span></span></div>
              <div class="raffle-title-box">
                <h2>RIFA</h2>
                <h3>SOLIDARIA</h3>
              </div>
              <div class="cost-badge" id="preview-cost-box">Costo de cada número: <strong>$1.000</strong></div>
            </div>
            
            <div class="header-right">
              <div class="beneficiary-text" id="preview-description-box">
                RIFA SOLIDARIA A BENEFICIO DE MIGUEL RAÚL GÓMEZ. CADA NÚMERO ES UNA OPORTUNIDAD PARA AYUDAR Y MARCAR LA DIFERENCIA.
              </div>
            </div>
          </div>
          
          <!-- Middle section (Prizes) -->
          <div class="prizes-section">
            <h4>Premios:</h4>
            <ul class="prizes-grid" id="preview-prizes-grid">
              <!-- Populated dynamically via JS -->
            </ul>
            <div id="preview-surprise-container">
              <!-- Populated dynamically via JS -->
            </div>
          </div>
          
          <!-- Table section (Participants) -->
          <div class="table-section">
            <table class="participants-table">
              <thead>
                <tr>
                  <th class="th-no">NO.</th>
                  <th class="th-name">NOMBRE DE LA PERSONA</th>
                  <th class="th-phone">TELÉFONO</th>
                </tr>
              </thead>
              <tbody id="preview-table-body">
                <!-- Populated dynamically via JS -->
              </tbody>
            </table>
          </div>
          
          <!-- Bottom section (Footer) -->
          <div class="sheet-footer">
            <div class="draw-date" id="preview-date-box">“EL SORTEO SE REALIZARÁ EL DÍA 23 MAYO”</div>
            <div class="footer-slogan" id="preview-slogan-box">TU APOYO CUENTA MÁS DE LO QUE IMAGINAS.</div>
          </div>

        </div>
      </div>
