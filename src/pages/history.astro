---
import { getDb } from '../lib/db';
import { getUserFromRequest } from '../lib/auth';
import { ObjectId } from 'mongodb';

const user = await getUserFromRequest(Astro.request);
if (!user) {
  return Astro.redirect('/login');
}

const db = await getDb();
let errorMsg = '';
let successMsg = '';

// Handle actions (delete, draw)
if (Astro.request.method === 'POST') {
  try {
    const formData = await Astro.request.formData();
    const action = formData.get('action');
    const raffleIdStr = formData.get('raffleId')?.toString() || '';

    if (!raffleIdStr) throw new Error('ID de rifa no proporcionado');
    const raffleId = new ObjectId(raffleIdStr);

    // Verify ownership
    const raffle = await db.collection('raffles').findOne({ _id: raffleId, userId: user._id });
    if (!raffle) {
      throw new Error('Rifa no encontrada');
    }

    if (action === 'delete') {
      await db.collection('raffles').deleteOne({ _id: raffleId });
      successMsg = 'Rifa eliminada correctamente';
    } else if (action === 'draw') {
      // Perform draw
      const participants = raffle.participants || [];
      if (participants.length === 0) {
        throw new Error('No hay ventas registradas para realizar el sorteo');
      }

      const prizes = raffle.prizes || [];
      const hasSurprise = raffle.hasSurprise;
      const surprisePrizeText = raffle.surprisePrize || '';

      const allPrizesList = [...prizes];
      if (hasSurprise && surprisePrizeText) {
        allPrizesList.push(surprisePrizeText);
      }

      if (allPrizesList.length === 0) {
        throw new Error('No hay premios configurados en esta rifa');
      }

      // Select winners randomly from 1 to total rows
      const winners = [];
      const totalTickets = raffle.rows || 10;
      const pool = [];
      for (let i = 1; i <= totalTickets; i++) {
        pool.push(i);
      }

      allPrizesList.forEach((prizeName, prizeIndex) => {
        if (pool.length === 0) return;
        // Pick a random ticket from the remaining pool
        const randomIndex = Math.floor(Math.random() * pool.length);
        const winningNumber = pool.splice(randomIndex, 1)[0];

        winners.push({
          prizeIndex: prizeIndex + 1,
          prizeName,
          winningNumber,
          winnerName: 'Verificar en hoja'
        });
      });

      // Update in DB
      await db.collection('raffles').updateOne(
        { _id: raffleId },
        { 
          $set: { 
            status: 'finalizada',
            winners,
            updatedAt: new Date()
          } 
        }
      );

      successMsg = '¡Sorteo realizado con éxito!';
    }
  } catch (err: any) {
    errorMsg = err.message || 'Ocurrió un error inesperado';
  }
}

// Fetch all user's raffles
const raffles = await db.collection('raffles').find({ userId: user._id }).sort({ createdAt: -1 }).toArray();

function formatMoney(amount: number) {
  return '$' + amount.toLocaleString('es-CL');
}

function parseTicketPrice(priceStr: string) {
  if (!priceStr) return 0;
  return parseInt(priceStr.replace(/\D/g, '')) || 0;
}
---

<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Historial de Rifas - Creador de Rifas</title>
  <link rel="icon" type="image/jpeg" href="/favicon.jpg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;800&display=swap" rel="stylesheet">
  <style>
    :root {
      --bg-dark: #0a0f0d;
      --card-bg: rgba(255, 255, 255, 0.03);
      --border-color: rgba(255, 255, 255, 0.08);
      --text-light: #f3f4f6;
      --text-gray: #9ca3af;
      --accent: #4b5d4a;
      --accent-hover: #3d4c3c;
      --red: #ef4444;
      --red-hover: #dc2626;
      --green: #10b981;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      font-family: 'Outfit', sans-serif;
      background: var(--bg-dark);
      background-image: 
        radial-gradient(at 10% 20%, rgba(75, 93, 74, 0.15) 0px, transparent 50%),
        radial-gradient(at 90% 80%, rgba(44, 90, 69, 0.12) 0px, transparent 50%);
      color: var(--text-light);
      min-height: 100vh;
      padding: 40px 20px;
    }

    .container {
      width: 100%;
      max-width: 1000px;
      margin: 0 auto;
    }

    .top-bar {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 40px;
      border-bottom: 1px solid var(--border-color);
      padding-bottom: 20px;
    }

    .top-bar h1 {
      font-size: 26px;
      font-weight: 800;
      letter-spacing: 1px;
    }

    .actions-top {
      display: flex;
      gap: 12px;
    }

    .btn {
      display: inline-flex;
      align-items: center;
      gap: 8px;
      padding: 10px 16px;
      border-radius: 8px;
      font-family: inherit;
      font-size: 14px;
      font-weight: 600;
      cursor: pointer;
      transition: all 0.2s;
      text-decoration: none;
      border: 1px solid transparent;
    }

    .btn-primary {
      background: var(--accent);
      color: var(--text-light);
    }

    .btn-primary:hover {
      background: var(--accent-hover);
    }

    .btn-secondary {
      background: rgba(255, 255, 255, 0.04);
      border-color: var(--border-color);
      color: var(--text-light);
    }

    .btn-secondary:hover {
      background: rgba(255, 255, 255, 0.08);
    }

    .btn-danger {
      background: rgba(239, 68, 68, 0.1);
      border-color: rgba(239, 68, 68, 0.2);
      color: var(--red);
    }

    .btn-danger:hover {
      background: rgba(239, 68, 68, 0.2);
    }

    .alert {
      padding: 12px 16px;
      border-radius: 8px;
      font-size: 14px;
      margin-bottom: 25px;
      display: flex;
      align-items: center;
      gap: 8px;
    }

    .alert-error {
      background: rgba(239, 68, 68, 0.1);
      border: 1px solid rgba(239, 68, 68, 0.2);
      color: var(--red);
    }

    .alert-success {
      background: rgba(16, 185, 129, 0.1);
      border: 1px solid rgba(16, 185, 129, 0.2);
      color: var(--green);
    }

    .raffles-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 25px;
    }

    .raffle-card {
      background: var(--card-bg);
      backdrop-filter: blur(12px);
      -webkit-backdrop-filter: blur(12px);
      border: 1px solid var(--border-color);
      border-radius: 12px;
      padding: 24px;
      box-shadow: 0 8px 32px rgba(0, 0, 0, 0.3);
    }

    .card-header {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      margin-bottom: 16px;
    }

    .card-header h2 {
      font-size: 20px;
      font-weight: 700;
      color: var(--text-light);
      margin-bottom: 4px;
    }

    .card-header p {
      font-size: 13px;
      color: var(--text-gray);
    }

    .badge {
      display: inline-block;
      padding: 4px 10px;
      border-radius: 999px;
      font-size: 11px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .badge-active {
      background: rgba(16, 185, 129, 0.1);
      color: var(--green);
      border: 1px solid rgba(16, 185, 129, 0.2);
    }

    .badge-completed {
      background: rgba(255, 255, 255, 0.05);
      color: var(--text-gray);
      border: 1px solid var(--border-color);
    }

    .card-body {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 20px;
      margin-bottom: 24px;
      border-top: 1px solid var(--border-color);
      border-bottom: 1px solid var(--border-color);
      padding: 16px 0;
    }

    @media (max-width: 600px) {
      .card-body {
        grid-template-columns: 1fr;
      }
    }

    .info-block {
      display: flex;
      flex-direction: column;
      gap: 4px;
    }

    .info-block span {
      font-size: 11px;
      text-transform: uppercase;
      font-weight: 600;
      letter-spacing: 0.5px;
      color: var(--text-gray);
    }

    .info-block strong {
      font-size: 16px;
      font-weight: 700;
      color: var(--text-light);
    }

    .card-actions {
      display: flex;
      justify-content: flex-end;
      gap: 12px;
      flex-wrap: wrap;
    }

    .winners-section {
      grid-column: 1 / -1;
      background: rgba(255, 255, 255, 0.01);
      border: 1px solid var(--border-color);
      border-radius: 8px;
      padding: 16px;
      margin-top: 10px;
    }

    .winners-section h3 {
      font-size: 14px;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.5px;
      color: var(--accent);
      margin-bottom: 12px;
      display: flex;
      align-items: center;
      gap: 6px;
    }

    .winners-list {
      list-style: none;
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 8px;
    }

    .winners-list li {
      font-size: 13px;
      color: var(--text-light);
      background: rgba(255, 255, 255, 0.02);
      padding: 8px 12px;
      border-radius: 6px;
      border: 1px solid var(--border-color);
      display: flex;
      justify-content: space-between;
    }

    .winners-list li span {
      color: var(--text-gray);
    }

    .no-raffles {
      text-align: center;
      padding: 60px 20px;
      background: var(--card-bg);
      border-radius: 12px;
      border: 1px solid var(--border-color);
    }

    .no-raffles h3 {
      font-size: 18px;
      margin-bottom: 8px;
    }

    .no-raffles p {
      color: var(--text-gray);
      margin-bottom: 24px;
      font-size: 14px;
    }
  </style>
</head>
<body>
  <div class="container">
    <div class="top-bar">
      <div>
        <h1>Historial de Rifas</h1>
        <p style="color: var(--text-gray); font-size: 14px; margin-top: 4px;">Hola, {user.username} • Gestiona tus boletos y realiza sorteos</p>
      </div>
      <div class="actions-top">
        <a href="/" class="btn btn-primary">
          <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="12" y1="5" x2="12" y2="19"></line>
            <line x1="5" y1="12" x2="19" y2="12"></line>
          </svg>
          Nueva Rifa
        </a>
        <a href="/logout" class="btn btn-secondary">Salir</a>
      </div>
    </div>

    {errorMsg && (
      <div class="alert alert-error">
        <svg style="width: 18px; height: 18px; flex-shrink: 0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="8" x2="12" y2="12"></line>
          <line x1="12" y1="16" x2="12.01" y2="16"></line>
        </svg>
        <span>{errorMsg}</span>
      </div>
    )}

    {successMsg && (
      <div class="alert alert-success">
        <svg style="width: 18px; height: 18px; flex-shrink: 0;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
          <polyline points="22 4 12 14.01 9 11.01"></polyline>
        </svg>
        <span>{successMsg}</span>
      </div>
    )}

    {raffles.length === 0 ? (
      <div class="no-raffles">
        <h3>Aún no tienes rifas</h3>
        <p>Crea tu primera rifa en el editor para comenzar a gestionar participantes y premios.</p>
        <a href="/" class="btn btn-primary">Diseñar Rifa</a>
      </div>
    ) : (
      <div class="raffles-grid">
        {raffles.map((raffle) => {
          const soldTicketsCount = raffle.participants?.reduce((sum: number, p: any) => {
            const status = p.status || (p.isComplete ? 'complete' : 'partial');
            if (status === 'complete') return sum + (raffle.rows || 10);
            if (status === 'partial') return sum + (p.quantity || 0);
            return sum;
          }, 0) || 0;
          const ticketPrice = parseTicketPrice(raffle.cost);
          const moneyRaised = soldTicketsCount * ticketPrice;
          const isCompleted = raffle.status === 'finalizada';

          return (
            <div class="raffle-card">
              <div class="card-header">
                <div>
                  <h2>{raffle.beneficiary || 'Sin Beneficiario'}</h2>
                  <p>Creado el {new Date(raffle.createdAt).toLocaleDateString('es-CL')} • {raffle.date}</p>
                </div>
                <span class={`badge ${isCompleted ? 'badge-completed' : 'badge-active'}`}>
                  {isCompleted ? 'Finalizada' : 'Activa'}
                </span>
              </div>

              <div class="card-body">
                <div class="info-block">
                  <span>Boletos Vendidos</span>
                  <strong>{soldTicketsCount} boletos</strong>
                </div>
                <div class="info-block">
                  <span>Dinero Recaudado</span>
                  <strong style="color: var(--green);">{formatMoney(moneyRaised)}</strong>
                </div>

                {isCompleted && raffle.winners && raffle.winners.length > 0 && (
                  <div class="winners-section">
                    <h3>
                      <svg style="width: 16px; height: 16px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"></path>
                      </svg>
                      Ganadores del Sorteo
                    </h3>
                    <ul class="winners-list">
                      {raffle.winners.map((winner: any) => (
                        <li key={winner.prizeIndex}>
                          <div>
                            <strong>#{winner.winningNumber}</strong> • {winner.winnerName}
                          </div>
                          <span>{winner.prizeName}</span>
                        </li>
                      ))}
                    </ul>
                  </div>
                )}
              </div>

              <div class="card-actions">
                <a href={`/?id=${raffle._id.toString()}`} class="btn btn-secondary">
                  <svg style="width: 14px; height: 14px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                    <path d="M18.5 2.5a2.121 2.121 0 1 1 3 3L12 15l-4 1 1-4z"></path>
                  </svg>
                  Cargar en Editor
                </a>

                {!isCompleted && (
                  <form method="POST" style="display:inline;" onsubmit="return confirm('¿Seguro que quieres realizar el sorteo? Esto seleccionará ganadores aleatorios entre los números vendidos.');">
                    <input type="hidden" name="action" value="draw">
                    <input type="hidden" name="raffleId" value={raffle._id.toString()}>
                    <button type="submit" class="btn btn-primary" disabled={soldTicketsCount === 0} title={soldTicketsCount === 0 ? 'Debes vender al menos un número para sortear' : ''}>
                      <svg style="width: 14px; height: 14px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <polyline points="23 4 23 10 17 10"></polyline>
                        <path d="M20.49 15a9 9 0 1 1-2.12-9.36L23 10"></path>
                      </svg>
                      Realizar Sorteo
                    </button>
                  </form>
                )}

                <form method="POST" style="display:inline;" onsubmit="return confirm('¿Estás seguro de que quieres eliminar esta rifa? Esta acción no se puede deshacer.');">
                  <input type="hidden" name="action" value="delete">
                  <input type="hidden" name="raffleId" value={raffle._id.toString()}>
                  <button type="submit" class="btn btn-danger">
                    <svg style="width: 14px; height: 14px;" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <polyline points="3 6 5 6 21 6"></polyline>
                      <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"></path>
                      <line x1="10" y1="11" x2="10" y2="17"></line>
                      <line x1="14" y1="11" x2="14" y2="17"></line>
                    </svg>
                    Eliminar
                  </button>
                </form>
              </div>
            </div>
          );
        })}
      </div>
    )}
  </div>
</body>
</html>
